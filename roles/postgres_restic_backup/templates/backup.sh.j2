#!/bin/bash
set -euo pipefail

# Source environment variables
source "{{ postgres_restic_backup_dir }}/env"

# Dump all PostgreSQL databases and pipe directly to restic
docker exec {{ postgres_restic_backup_postgres_container }} \
  pg_dumpall -U {{ postgres_restic_backup_postgres_user }} \
  | restic backup --stdin --stdin-filename "pg_dumpall.sql"

# Apply retention policy and prune old snapshots
restic forget \
  --keep-daily {{ postgres_restic_backup_retention_daily }} \
  --keep-weekly {{ postgres_restic_backup_retention_weekly }} \
  --keep-monthly {{ postgres_restic_backup_retention_monthly }} \
  --prune
